// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ENUM HERE

enum UserLevel {
  Basic
  Premium
  Volunteer
  Contributor
  Moderator
  Director
  SuperAdmin
}

enum PostStatus {
  Draft
  Review
  Aprove
  Block
}

enum MediaType {
  Image
  File
  Video
  Audio
}



model User {
  id            String    @id
  name          String
  username      String   @unique @db.VarChar(20)
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  phone_number  String?
  bio           String?
  level         UserLevel @default(Basic)
  // social
  telegram_link String?
  linkedin_link String?
  github_link String?
  youtube_link String?
  tiktok_link String?
  facebook_link String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  posts         Post[]
  likes     Like[]
  comments  Comment[]
  settings  UserSettings? 
  media     Media[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model UserSettings {
  id        String   @id
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String   @default("system")
  showProfileInMemberList Boolean @default(true)
  language  String   @default("en")
  fontFamily String @default("system")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("userSetting")
}

model Post{
  id Int @id @default(autoincrement())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  slug          String    @unique @default(uuid()) @db.VarChar(100)
  summary       String
  content       String    @db.Text
  mediaId       Int?                   // relation to Media table
  media         Media?    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  status        PostStatus    @default(Draft)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  likes     Like[]
  comments  Comment[]

  @@map("post")
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    String
  postId    Int
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Comment {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  userId    String
  postId    Int
  
  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("comment")
}

model Media {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String                    // original file name
  url       String                    // storage URL (UploadThing, S3, etc.)
  mediaType MediaType @default(Image) // Image | File | Video | Audio
  extension String                    // e.g. "jpg", "pdf"
  size      Int                       // bytes
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  posts     Post[]

  @@map("media")
}